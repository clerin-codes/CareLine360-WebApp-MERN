{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit",
    "test:unit": "jest tests/unit --detectOpenHandles --forceExit",
    "test:integration": "jest tests/integration --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
    "test:patient": "jest tests/unit/patient tests/integration/patient --detectOpenHandles --forceExit --verbose",
    "test:patient:unit": "jest tests/unit/patient --detectOpenHandles --forceExit --verbose",
    "test:patient:integration": "jest tests/integration/patient --detectOpenHandles --forceExit --verbose",
    "test:patient:perf": "npx artillery run tests/artillery/patient-load-test.yml",
    "test:patient:perf:report": "npx artillery run --output patient-report.json tests/artillery/patient-load-test.yml && npx artillery report patient-report.json",
    "test:admin": "jest tests/unit/admin tests/integration/admin --detectOpenHandles --forceExit --verbose",
    "test:admin:unit": "jest tests/unit/admin --detectOpenHandles --forceExit --verbose",
    "test:admin:integration": "jest tests/integration/admin --detectOpenHandles --forceExit --verbose",
    "test:admin:perf": "npx artillery run tests/artillery/admin-load-test.yml",
    "test:admin:perf:report": "npx artillery run --output admin-report.json tests/artillery/admin-load-test.yml && npx artillery report admin-report.json",
    "test:appointment": "jest tests/unit/appointment tests/integration/appointment --detectOpenHandles --forceExit --verbose",
    "test:appointment:unit": "jest tests/unit/appointment --detectOpenHandles --forceExit --verbose",
    "test:appointment:integration": "jest tests/integration/appointment --detectOpenHandles --forceExit --verbose",
    "test:appointment:perf": "npx artillery run tests/artillery/appointment-load-test.yml",
    "test:appointment:perf:report": "npx artillery run --output appointment-report.json tests/artillery/appointment-load-test.yml && npx artillery report appointment-report.json",
    "test:doctor": "jest tests/unit/doctor tests/integration/doctor --detectOpenHandles --forceExit --verbose",
    "test:doctor:unit": "jest tests/unit/doctor --detectOpenHandles --forceExit --verbose",
    "test:doctor:integration": "jest tests/integration/doctor --detectOpenHandles --forceExit --verbose",
    "test:doctor:perf": "npx artillery run tests/artillery/doctor-load-test.yml",
    "test:doctor:perf:report": "npx artillery run --output doctor-report.json tests/artillery/doctor-load-test.yml && npx artillery report doctor-report.json",
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "fs-extra": "^11.3.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
