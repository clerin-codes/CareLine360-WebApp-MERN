{
  "info": {
    "_postman_id": "appointment-module-001",
    "name": "CareLine360 - Appointment Module",
    "description": "Complete API documentation for Appointment Module endpoints managing the complete appointment lifecycle including creation, scheduling, status transitions, rescheduling, and cancellation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Patient",
          "id": "appointment-login-patient-001",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientIdentifier}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate patient and get JWT token"
          },
          "response": []
        },
        {
          "name": "Login Doctor",
          "id": "appointment-login-doctor-001",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorIdentifier}}\",\n  \"password\": \"{{doctorPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate doctor and get JWT token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "CRUD Operations",
      "item": [
        {
          "name": "Create Appointment",
          "id": "appointment-crud-create-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctor\": \"{{doctorId}}\",\n  \"date\": \"2024-02-15T00:00:00.000Z\",\n  \"time\": \"10:00 AM\",\n  \"consultationType\": \"video\",\n  \"symptoms\": \"Persistent headache and fever\",\n  \"notes\": \"Had fever for 3 days, temperature around 101°F\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"]
            },
            "description": "Create new appointment with doctor"
          },
          "response": []
        },
        {
          "name": "Get All Appointments",
          "id": "appointment-crud-get-all-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments?status=&page=1&limit=10&sortBy=date&sortOrder=asc",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"],
              "query": [
                {
                  "key": "status",
                  "value": ""
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "date"
                },
                {
                  "key": "sortOrder",
                  "value": "asc"
                }
              ]
            },
            "description": "Retrieve appointments with filtering and pagination"
          },
          "response": []
        },
        {
          "name": "Get Appointment Details",
          "id": "appointment-crud-get-details-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            },
            "description": "Get detailed information about specific appointment"
          },
          "response": []
        },
        {
          "name": "Update Appointment",
          "id": "appointment-crud-update-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symptoms\": \"Updated symptoms description\",\n  \"notes\": \"Updated notes\",\n  \"priority\": \"urgent\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            },
            "description": "Update appointment details"
          },
          "response": []
        },
        {
          "name": "Delete Appointment",
          "id": "appointment-crud-delete-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}"]
            },
            "description": "Delete (soft delete) an appointment"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Workflow Management",
      "item": [
        {
          "name": "Update Appointment Status",
          "id": "appointment-workflow-status-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{doctorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/status",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}", "status"]
            },
            "description": "Transition appointment status (pending → confirmed → completed OR cancelled)"
          },
          "response": []
        },
        {
          "name": "Reschedule Appointment",
          "id": "appointment-workflow-reschedule-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2024-02-20T00:00:00.000Z\",\n  \"time\": \"02:00 PM\",\n  \"reason\": \"Patient requested reschedule due to work conflict\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/reschedule",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}", "reschedule"]
            },
            "description": "Reschedule appointment to new date and time"
          },
          "response": []
        },
        {
          "name": "Cancel Appointment",
          "id": "appointment-workflow-cancel-001",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Patient is not feeling well and needs to reschedule\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/cancel",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}", "cancel"]
            },
            "description": "Cancel appointment with optional reason"
          },
          "response": []
        }
      ]
    }
  ]
}
